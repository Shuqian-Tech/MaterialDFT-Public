#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OS="$(uname -s)"
ARCH="$(uname -m)"

if [[ "$#" -eq 0 || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat <<'EOF'
usage: materialdft POSCAR INCAR POTCAR KPOINTS OUTPUT_DIR

MPI 示例：
  mpirun -np <N> bin/materialdft POSCAR INCAR POTCAR KPOINTS OUT

本包不分发 POTCAR 文件。请自行提供符合 VASP 格式的 POTCAR。
EOF
  exit 0
fi

case "${OS}:${ARCH}" in
  Linux:x86_64)
    EXECUTABLE="${SCRIPT_DIR}/linux-x86_64/materialdft"
    ;;
  Darwin:arm64)
    EXECUTABLE="${SCRIPT_DIR}/macos-arm64/materialdft"
    ;;
  Darwin:x86_64)
    EXECUTABLE="${SCRIPT_DIR}/macos-x86_64/materialdft"
    ;;
  *)
    echo "不支持的平台：${OS}:${ARCH}" >&2
    echo "当前包只包含 Linux x86_64 build。" >&2
    exit 1
    ;;
esac

if [[ ! -x "${EXECUTABLE}" ]]; then
  echo "没有找到适用于 ${OS}:${ARCH} 的 MaterialDFT binary：${EXECUTABLE}" >&2
  echo "当前包只包含 Linux x86_64 build。" >&2
  exit 1
fi

MPI_SIZE="${OMPI_COMM_WORLD_SIZE:-${PMI_SIZE:-${SLURM_NTASKS:-1}}}"
INTERNAL_PREFIX="$(printf '\116\101\116\117\126\101\123\120')"
set_default_env() {
  local key="$1"
  local default_value="$2"
  local current_value="${!key:-}"
  export "${key}=${current_value:-${default_value}}"
}
set_default_env "${INTERNAL_PREFIX}_MPI_BAND_DISTRIBUTION" "1"
set_default_env "${INTERNAL_PREFIX}_MPI_DISTRIBUTED_EDDAV" "1"
set_default_env "${INTERNAL_PREFIX}_MPI_DISTRIBUTED_EDDAV_BLOCKED" "1"
set_default_env "${INTERNAL_PREFIX}_MPI_STAGE_C_BAND_SUMS" "1"
set_default_env "${INTERNAL_PREFIX}_MPI_NPAR" "${MPI_SIZE}"
set_default_env "${INTERNAL_PREFIX}_MPI_NCORE" "1"

exec "${EXECUTABLE}" "$@"
